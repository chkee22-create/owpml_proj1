# Copy this file to .env before running docker compose.
# This root .env is read by docker-compose.yml during frontend build.

# Google login frontend settings, not Gemini/LLM.
# Use the same OAuth Client ID in backend/.env as GOOGLE_CLIENT_ID.
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

