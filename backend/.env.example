APP_NAME=PaperMate API
APP_ENV=development
DEBUG=false
ENABLE_API_DOCS=false
LOG_LEVEL=INFO

MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=papermate
MONGO_TIMEOUT_MS=2000

JWT_SECRET_KEY=change-this-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM API keys live on the backend only.
# Copy this file to .env and put your real keys there.
# Use openai for OpenAI, or google for Gemini.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Semantic grounding is part of the default analysis engine.
ENABLE_BERT_GROUNDING=true
BERT_GROUNDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# For stronger multilingual grounding, use Qwen/Qwen3-Embedding-8B on a GPU machine.
# BERT_GROUNDING_MODEL=Qwen/Qwen3-Embedding-8B
BERT_GROUNDING_THRESHOLD=0.62
BERT_GROUNDING_INSTRUCTION=Given an answer sentence, retrieve the most relevant source passage from the uploaded document.

# KoBERTopic-inspired topic extraction is part of the default analysis engine.
ENABLE_TOPIC_MODELING=true
TOPIC_MODEL_BACKEND=bertopic
TOPIC_MODEL_LIMIT=5

MAX_UPLOAD_MB=25
MAX_UPLOAD_FILES=10
HWPX_JAR=
FRONTEND_BUILD_DIR=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
